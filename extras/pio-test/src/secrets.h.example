#define WIFI_SSID "YOUR_SSID"        // 2.4 GHz only (ESP32 cannot use 5 GHz)
#define WIFI_PASS "YOUR_PASSWORD"

// Event id played by Button A (command mode). Must exist in the kit deployed to
// your Hapbeat via Studio. Default = the standard verification event.
#define HAPBEAT_EVENT "sample-kit.sine_100hz"
